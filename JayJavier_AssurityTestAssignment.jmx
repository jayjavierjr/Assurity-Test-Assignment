<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Test Plan">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="BaseDIR" elementType="Argument">
            <stringProp name="Argument.name">BaseDIR</stringProp>
            <stringProp name="Argument.value">${__BeanShell(import org.apache.jmeter.services.FileServer; FileServer.getFileServer().getBaseDir();)}\</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>
      <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="CSVFile - CategoryID">
        <stringProp name="delimiter">,</stringProp>
        <stringProp name="fileEncoding"></stringProp>
        <stringProp name="filename">${BaseDIR}data\CategoryID.csv</stringProp>
        <boolProp name="ignoreFirstLine">true</boolProp>
        <boolProp name="quotedData">false</boolProp>
        <boolProp name="recycle">true</boolProp>
        <stringProp name="shareMode">shareMode.all</stringProp>
        <boolProp name="stopThread">false</boolProp>
        <stringProp name="variableNames"></stringProp>
      </CSVDataSet>
      <hashTree/>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Test Configuration" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="timeStamp" elementType="Argument">
            <stringProp name="Argument.name">timeStamp</stringProp>
            <stringProp name="Argument.value">${__time(ddMM_HHmmss,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="threads" elementType="Argument">
            <stringProp name="Argument.name">threads</stringProp>
            <stringProp name="Argument.value">${__P(threads,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">5</stringProp>
          </elementProp>
          <elementProp name="rampup" elementType="Argument">
            <stringProp name="Argument.name">rampup</stringProp>
            <stringProp name="Argument.value">${__P(rampup,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">5</stringProp>
          </elementProp>
          <elementProp name="duration" elementType="Argument">
            <stringProp name="Argument.name">duration</stringProp>
            <stringProp name="Argument.value">${__P(duration,65)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">60</stringProp>
          </elementProp>
          <elementProp name="throughput" elementType="Argument">
            <stringProp name="Argument.name">throughput</stringProp>
            <stringProp name="Argument.value">${__P(throughput,10)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">10</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Catalogue">
        <stringProp name="TestPlan.comments">${VUsers} - ${Rampup}</stringProp>
        <stringProp name="ThreadGroup.num_threads">${threads}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${rampup}</stringProp>
        <stringProp name="ThreadGroup.duration">${duration}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">startnextloop</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <intProp name="LoopController.loops">-1</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="Transaction_01_Catalogue">
          <boolProp name="TransactionController.includeTimers">false</boolProp>
        </TransactionController>
        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="01_01 API_Catalogue">
            <stringProp name="HTTPSampler.path">https://api.tmsandbox.co.nz/v1/Categories/${CategoryID}/Details.json?catalogue=false</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Response Code Validation: HTTP 200" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="49586">200</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message"></stringProp>
              <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">16</intProp>
            </ResponseAssertion>
            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Response Message Validation: CategoryID &amp; CanRelist" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="-145856782">&quot;CategoryId&quot;:${CategoryID},</stringProp>
                <stringProp name="1740699367">&quot;CanRelist&quot;:true,</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message">Test failed: text expected to contain {&quot;CanRelist&quot;:true} for CategoryId: ${CategoryID}</stringProp>
              <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">16</intProp>
            </ResponseAssertion>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Validate CategoryID &amp; CanRelist Fields" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def response = prev.getResponseDataAsString()
def categoryId = vars.get(&quot;CategoryID&quot;)

if (response.contains(&quot;\&quot;CategoryId\&quot;:${categoryId}&quot;) &amp;&amp;
    response.contains(&quot;\&quot;CanRelist\&quot;:true&quot;)) {

    log.info(&quot;Validation PASSED for CategoryID=${categoryId}&quot;)
    vars.put(&quot;ResponseMessageValidationResult&quot;, &quot;PASSED&quot;)

} else {

    log.warn(&quot;Validation FAILED for CategoryID=${categoryId}&quot;)
    vars.put(&quot;ResponseMessageValidationResult&quot;, &quot;FAILED&quot;)

    // keep request successful
    prev.setSuccessful(true)
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <BoundaryExtractor guiclass="BoundaryExtractorGui" testclass="BoundaryExtractor" testname="c_Name" enabled="true">
              <stringProp name="BoundaryExtractor.useHeaders">false</stringProp>
              <stringProp name="BoundaryExtractor.refname">c_Name</stringProp>
              <stringProp name="BoundaryExtractor.lboundary">&quot;Name&quot;:&quot;</stringProp>
              <stringProp name="BoundaryExtractor.rboundary">&quot;</stringProp>
              <stringProp name="BoundaryExtractor.default"></stringProp>
              <boolProp name="BoundaryExtractor.default_empty_value">false</boolProp>
              <stringProp name="BoundaryExtractor.match_number">1</stringProp>
            </BoundaryExtractor>
            <hashTree/>
            <BoundaryExtractor guiclass="BoundaryExtractorGui" testclass="BoundaryExtractor" testname="c_Path" enabled="true">
              <stringProp name="BoundaryExtractor.useHeaders">false</stringProp>
              <stringProp name="BoundaryExtractor.refname">c_Path</stringProp>
              <stringProp name="BoundaryExtractor.lboundary">&quot;Path&quot;:&quot;</stringProp>
              <stringProp name="BoundaryExtractor.rboundary">&quot;</stringProp>
              <stringProp name="BoundaryExtractor.default"></stringProp>
              <boolProp name="BoundaryExtractor.default_empty_value">false</boolProp>
              <stringProp name="BoundaryExtractor.match_number">$1$</stringProp>
            </BoundaryExtractor>
            <hashTree/>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="c_PromotionIDs" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">c_PromotionIDs</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.Promotions[*].Id</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="c_PromotionNames" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">c_PromotionNames</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.Promotions[*].Name</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="c_PromotionPrices" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">c_PromotionPrices</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.Promotions[*].Price</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">-1</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract Data to CSV File" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">//def timestamp = new Date().format(&quot;ddMM_HHmmss&quot;)
def timestamp = vars.get(&quot;timeStamp&quot;)
def filePath = vars.get(&quot;BaseDIR&quot;) + &quot;extract\\\\DataExtract_${timestamp}.csv&quot;

def loopCount = vars.get(&quot;__jm__Catalogue__idx&quot;) ?: &quot;0&quot;
def CategoryID = vars.get(&quot;CategoryID&quot;)
def Name = vars.get(&quot;c_Name&quot;)
def Path = vars.get(&quot;c_Path&quot;)
def matchNr = vars.get(&quot;c_PromotionIDs_matchNr&quot;) as int


def file = new File(filePath)

file.getParentFile().mkdirs()

/*
if (loopCount == &quot;0&quot;) {
	file &lt;&lt; &quot;Category ID,Name,Path,Promotion ID,Price\n&quot;
}
*/

for (int i = 1; i &lt;= matchNr; i++) {
    def promotionId = vars.get(&quot;c_PromotionIDs_&quot; + i)
    //def promotionNames = vars.get(&quot;c_PromotionNames_&quot; + i)
    def promotionPrices = vars.get(&quot;c_PromotionPrices_&quot; + i)
    
    //file &lt;&lt; CategoryID + &quot;,&quot; + Name + &quot;,&quot; + Path + &quot;,&quot; + promotionId + &quot;,&quot; + promotionNames + &quot;,&quot; + promotionPrices + &quot;\n&quot;
    file &lt;&lt; CategoryID + &quot;,&quot; + Name + &quot;,&quot; + Path + &quot;,&quot; + promotionId + &quot;,&quot; + promotionPrices +&quot;\n&quot;
}

log.info(&quot;Data extracted to: &quot; + filePath)

vars.put(&quot;GeneratedCSV&quot;, filePath)</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
          <ConstantThroughputTimer guiclass="TestBeanGUI" testclass="ConstantThroughputTimer" testname="Constant Throughput Timer">
            <intProp name="calcMode">2</intProp>
            <stringProp name="throughput">${throughput}</stringProp>
          </ConstantThroughputTimer>
          <hashTree/>
